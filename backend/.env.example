# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose: postgresql+asyncpg://postgres:postgres@db:5432/toplu_alisveris
# Local:          postgresql+asyncpg://localhost/toplu_alisveris
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/toplu_alisveris

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose: redis://redis:6379/0
# Local:          redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── FX Rate Fallback ─────────────────────────────────────────────────────────
# Used when live USD/TRY rate cannot be fetched
USD_TRY_FALLBACK_RATE=38.0
