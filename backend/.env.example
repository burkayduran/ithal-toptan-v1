# ─── Required ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-hex-string

# PostgreSQL async URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/toplu_alisveris

# Redis URL (use /0 for dev, /1 for tests)
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ─── MoQ sync strategy ────────────────────────────────────────────────────────
# strict: sync Redis counter from DB after every wishlist write (safest, slower)
# lazy:   update Redis via increment/decrement delta; full sync only on cache miss
#         (faster under load; brief inconsistencies heal automatically)
MOQ_SYNC_STRATEGY=strict

# ─── Email ────────────────────────────────────────────────────────────────────
# resend | fake  (use "fake" for local dev – logs emails to stdout)
EMAIL_PROVIDER=fake
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Frontend CORS ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── iyzico payment (optional) ────────────────────────────────────────────────
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─── TCMB exchange rate API ───────────────────────────────────────────────────
TCMB_API_URL=https://evds2.tcmb.gov.tr
